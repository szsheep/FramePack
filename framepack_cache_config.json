{
  "cache": {
    "hf_cache_dir": "./hf_download",
    "model_cache_dir": "./models",
    "temp_cache_dir": "./temp",
    "max_cache_size_gb": 100,
    "auto_cleanup": true,
    "cleanup_threshold_gb": 80
  },
  "teacache": {
    "enabled": true,
    "rel_l1_thresh": 0.18,
    "rescale_coefficients": [
      732.3226126,
      -401.131952,
      67.5869174,
      -3.149878,
      0.0961237896
    ]
  },
  "localization": {
    "language": "zh",
    "region": "CN",
    "use_system_locale": false
  },
  "storage": {
    "prefer_local_storage": true,
    "local_storage_priority": [
      "ssd",
      "hdd"
    ],
    "backup_locations": [
      "/data/framepack_cache",
      "~/Documents/FramePack/cache"
    ]
  }
}